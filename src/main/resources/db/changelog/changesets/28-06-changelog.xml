<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="add-index-to-accounts-1" author="Эржан">
        <createIndex tableName="accounts" indexName="idx_accounts_client_id">
            <column name="client_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-payments-1" author="Эржан">
        <createIndex tableName="payments" indexName="idx_payments_debit_account_id">
            <column name="debit_account_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-payments-2" author="Эржан">
        <createIndex tableName="payments" indexName="idx_payments_credit_account_id">
            <column name="credit_account_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-payments-3" author="Эржан">
        <createIndex tableName="payments" indexName="idx_payments_created_at">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-outboxes-1" author="Эржан">
        <createIndex tableName="outboxes" indexName="idx_outboxes_payment_id">
            <column name="payment_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-outboxes-2" author="Эржан">
        <createIndex tableName="outboxes" indexName="idx_outboxes_published_at">
            <column name="published_at"/>
        </createIndex>
    </changeSet>
    <changeSet id="add-index-to-transactions-2" author="Эржан">
        <createIndex tableName="transactions" indexName="idx_transactions_payment_id">
            <column name="payment_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>